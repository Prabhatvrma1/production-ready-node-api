{
  "name": "aquisitions",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "imports": {
    "#controller": "./src/controller/*.js",
    "#validations": "./src/validations/*.js",
    "#config": "./src/config/*.js",
    "#models": "./src/models/*.js",
    "#middleware": "./src/middleware/*.js",
    "#routes": "./src/routes/*.js",
    "#services": "./src/services/*.js",
    "#utils": "./src/utils/*.js"
  },
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "lint:fix": "eslint . --fix",
    "format-check": "prettier --check .",
    "format:check": "prettier --check .",

    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "dev:docker": "sh ./scripts/setup-docker.sh",
    "dev:docker-win": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-docker-win.ps1",
    "prod:docker": "sh ./scripts/prod.sh",
    "prod:docker-win": "powershell -ExecutionPolicy Bypass -File ./scripts/prod-win.ps1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Prabhatvrma1/aquisitions.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Prabhatvrma1/aquisitions/issues"
  },
  "homepage": "https://github.com/Prabhatvrma1/aquisitions#readme",
  "dependencies": {
    "@arcjet/inspect": "^1.6.1",
    "@arcjet/node": "^1.6.1",
    "@neondatabase/serverless": "^1.1.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "pg": "^8.22.0",
    "prettier": "^3.9.4"
  }
}
